# ============================================
# Aniston HRMS — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://aniston:aniston_hrms_2026@localhost:5432/aniston_hrms?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this-too"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
API_URL="http://localhost:4000"

# File Storage (S3 compatible — use MinIO for local dev)
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="aniston-hrms"
STORAGE_REGION="us-east-1"

# Email (Microsoft 365)
MS365_CLIENT_ID=""
MS365_CLIENT_SECRET=""
MS365_TENANT_ID=""
MS365_SENDER_EMAIL=""

# AI Service
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_API_KEY="your-ai-service-key"

# DeepSeek
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# RAGFlow
RAGFLOW_API_URL=""
RAGFLOW_API_KEY=""

# Mapbox
MAPBOX_ACCESS_TOKEN=""

# Microsoft Teams
TEAMS_CLIENT_ID=""
TEAMS_CLIENT_SECRET=""
TEAMS_TENANT_ID=""

# Naukri RMS
NAUKRI_API_KEY=""
NAUKRI_API_SECRET=""

# Sentry
SENTRY_DSN=""
