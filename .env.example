# ============================================================
# Aniston HRMS — Environment Variables Template
# ============================================================
# HOW TO USE:
#   cp .env.example .env
#   Fill in every value marked REQUIRED before starting the server.
#   Variables are validated by Zod in backend/src/config/env.ts —
#   the server will refuse to start if REQUIRED vars are missing.
#
# WARNING: NEVER commit the real .env file to git.
#          Rotate any secrets that were accidentally exposed.
# ============================================================

# ---- Server ----
PORT=4000
NODE_ENV="development"
# URL where the React frontend is served (used for CORS + invitation links)
FRONTEND_URL="http://localhost:5173"
# Public URL of this API server (used in generated links/emails)
API_URL="http://localhost:4000"

# ---- Database (REQUIRED) ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/aniston_hrms?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- JWT (REQUIRED — use long random strings, min 64 hex chars each) ----
# Generate with: openssl rand -hex 64
JWT_SECRET="generate-with: openssl rand -hex 64"
# Generate with: openssl rand -hex 64
JWT_REFRESH_SECRET="generate-with: openssl rand -hex 64"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ---- AES-256-GCM Encryption (REQUIRED — used for Aadhaar, PAN, AI API keys) ----
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="generate-with: openssl rand -hex 32"

# ---- File Storage (S3-compatible — use MinIO for local dev) ----
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="aniston-hrms"
STORAGE_REGION="us-east-1"

# ---- SMTP Email (used by BullMQ email worker) ----
SMTP_HOST="smtp.office365.com"
SMTP_PORT=587
SMTP_USER="your-smtp-username@yourdomain.com"
SMTP_PASS="your-smtp-password-here"
SMTP_FROM="noreply@yourdomain.com"

# ---- Microsoft 365 OAuth (alternative to SMTP for email) ----
MS365_CLIENT_ID="your-ms365-app-client-id"
MS365_CLIENT_SECRET="your-ms365-app-client-secret"
MS365_TENANT_ID="your-ms365-tenant-id"
MS365_SENDER_EMAIL="sender@yourdomain.com"

# ---- AI Service (Docker-hosted Python FastAPI — OCR + fallback scoring) ----
# Leave as default if running via docker compose
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_API_KEY="your-ai-service-api-key-here"

# ---- AI Provider API Keys (managed via Settings → API Integrations in the app) ----
# These are stored AES-encrypted in the database per-org via AiApiConfig.
# The env vars below are only needed for local development / seeding defaults.
# Supported providers: OPENAI | DEEPSEEK | ANTHROPIC | GEMINI | CUSTOM

# OpenAI (optional — configure via Settings UI after login)
OPENAI_API_KEY="sk-...your-openai-key-here"
# Override base URL if using a proxy/router (e.g. OpenRouter)
OPENAI_BASE_URL="https://api.openai.com/v1"

# DeepSeek (default provider for resume scoring)
DEEPSEEK_API_KEY="your-deepseek-api-key-here"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Anthropic Claude (optional — configure via Settings UI after login)
ANTHROPIC_API_KEY="sk-ant-...your-anthropic-key-here"

# Google Gemini (optional — configure via Settings UI after login)
GEMINI_API_KEY="your-gemini-api-key-here"

# ---- RAGFlow (AI document search — optional) ----
RAGFLOW_API_URL="http://localhost:9380"
RAGFLOW_API_KEY="your-ragflow-api-key-here"

# ---- Mapbox (used for geofence attendance + GPS trail) ----
MAPBOX_ACCESS_TOKEN="pk.eyJ1...your-mapbox-token-here"

# ---- Microsoft Teams SSO ----
TEAMS_CLIENT_ID="your-teams-app-client-id"
TEAMS_CLIENT_SECRET="your-teams-app-client-secret"
TEAMS_TENANT_ID="your-teams-tenant-id"

# ---- Naukri RMS Integration (optional) ----
NAUKRI_API_KEY="your-naukri-api-key-here"
NAUKRI_API_SECRET="your-naukri-api-secret-here"

# ---- Sentry Error Monitoring (optional) ----
SENTRY_DSN="https://your-key@sentry.io/your-project-id"

# ---- Database Backup ----
# Set to "true" to force pg_dump via Docker instead of local binary
BACKUP_USE_DOCKER="false"
