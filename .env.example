# ============================================
# Aniston HRMS — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# Variables marked REQUIRED must be set for the server to start (validated by Zod in env.ts).

# ---- Server ----
PORT=4000
NODE_ENV="development"
# URL where the React frontend is served (used for CORS + invitation links)
FRONTEND_URL="http://localhost:5173"
# Public URL of this API server (used in generated links)
API_URL="http://localhost:4000"

# ---- Database (REQUIRED) ----
DATABASE_URL="postgresql://aniston:aniston_hrms_2026@localhost:5432/aniston_hrms?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- JWT (REQUIRED — use long random strings, min 32 chars each) ----
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this-too"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ---- AES-256-GCM Encryption (REQUIRED — used for Aadhaar, PAN, AI API keys) ----
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# ---- File Storage (S3 compatible — use MinIO for local dev) ----
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="aniston-hrms"
STORAGE_REGION="us-east-1"

# ---- SMTP Email (used by BullMQ email worker) ----
SMTP_HOST="smtp.office365.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@aniston.in"

# ---- Microsoft 365 OAuth (alternative to SMTP for email) ----
MS365_CLIENT_ID=""
MS365_CLIENT_SECRET=""
MS365_TENANT_ID=""
MS365_SENDER_EMAIL=""

# ---- AI Service (Docker-hosted Python FastAPI — OCR + fallback scoring) ----
# Leave as default if running via docker compose
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_API_KEY="your-ai-service-key"

# ---- AI Provider API Keys (managed via Settings → API Integrations in the app) ----
# These are stored encrypted in the database per-org via AiApiConfig.
# The env vars below are only needed for local development / seeding defaults.
# Supported providers: OPENAI | DEEPSEEK | ANTHROPIC | GEMINI | CUSTOM

# DeepSeek (default provider for resume scoring)
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# OpenAI (optional — configure via Settings UI after login)
OPENAI_API_KEY=""

# Anthropic Claude (optional — configure via Settings UI after login)
ANTHROPIC_API_KEY=""

# Google Gemini (optional — configure via Settings UI after login)
GEMINI_API_KEY=""

# ---- RAGFlow (AI document search — optional) ----
RAGFLOW_API_URL=""
RAGFLOW_API_KEY=""

# ---- Mapbox (used for geofence attendance + GPS trail) ----
MAPBOX_ACCESS_TOKEN=""

# ---- Microsoft Teams SSO ----
TEAMS_CLIENT_ID=""
TEAMS_CLIENT_SECRET=""
TEAMS_TENANT_ID=""

# ---- Naukri RMS Integration (optional) ----
NAUKRI_API_KEY=""
NAUKRI_API_SECRET=""

# ---- Sentry Error Monitoring (optional) ----
SENTRY_DSN=""
