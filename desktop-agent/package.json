{
  "name": "aniston-activity-agent",
  "version": "1.0.0",
  "description": "Aniston HRMS Desktop Activity Tracking Agent",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "tsc && electron .",
    "build": "tsc",
    "dist": "tsc && electron-builder",
    "dist:win": "tsc && electron-builder --win",
    "dist:mac": "tsc && electron-builder --mac",
    "dist:linux": "tsc && electron-builder --linux"
  },
  "dependencies": {
    "active-win": "^8.2.0",
    "screenshot-desktop": "^1.15.0",
    "desktop-idle": "^1.3.0",
    "electron-store": "^8.2.0",
    "node-fetch": "^2.7.0",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "electron": "^28.3.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "build": {
    "appId": "com.aniston.activity-agent",
    "productName": "Aniston Activity Agent",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true
    }
  }
}
