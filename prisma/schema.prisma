// =====================

enum McqCategory {
  INTELLIGENCE
  INTEGRITY
  ENERGY
}

enum PublicAppStatus {
  SUBMITTED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  SELECTED
  REJECTED
  ON_HOLD
}

model JobApplicationQuestion {
  id            String      @id @default(uuid())
  jobOpeningId  String
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String      // A, B, C, or D
  category      McqCategory
  aiGenerated   Boolean     @default(true)
  createdAt     DateTime    @default(now())

  jobOpening JobOpening @relation(fields: [jobOpeningId], references: [id])

  @@index([jobOpeningId])
}

model PublicApplication {
  id                String          @id @default(uuid())
  uid               String          @unique // 8-char alphanumeric
  jobOpeningId      String
  candidateName     String
  email             String?
  mobileNumber      String?
  city              String?
  experience        String?         // e.g. "Fresher", "1-2", "2-5", "5-10", "10+"
  currentDesignation String?
  preferredLocation String?
  willingToRelocate String?         // "yes", "no", "maybe"
  currentCTC        String?         // free-text e.g. "5 LPA"
  expectedCTC       String?
  noticePeriod      String?         // e.g. "Immediate", "15 days", "1 month", "2 months", "3 months"
  resumeUrl             String?
  resumeScoreData       Json?
  resumeMatchScore      Float?          // 0-100 resume-to-JD match from OCR analysis
  resumeText            String?         // Extracted plaintext from resume (for HR view)
  matchedKeywords       String[]        // JD keywords found in resume
  missingKeywords       String[]        // JD keywords NOT found in resume
  atsScore              Float?          // ATS compatibility score 0-100
  atsScoreData          Json?           // ATS score breakdown (sections, density, contact, etc.)
  mcqAnswers            Json?           // [{questionId, selectedOption}]
  mcqScore              Float?
  intelligenceScore     Float?
  integrityScore        Float?
  energyScore           Float?
  totalAiScore          Float?
  usedFallbackQuestions Boolean         @default(false) // true if AI MCQ gen failed, fallback used
  status                PublicAppStatus  @default(SUBMITTED)
  candidateUid          String           @unique // for tracking
  organizationId        String
  finalScore            Float?
  finalStatus           String?
  finalizedAt           DateTime?
  finalizedBy           String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  jobOpening        JobOpening       @relation(fields: [jobOpeningId], references: [id])
  interviewRounds   InterviewRound[]
  bulkResumeItem    BulkResumeItem?

  @@index([jobOpeningId])
  @@index([organizationId])
  @@index([candidateUid])
}

