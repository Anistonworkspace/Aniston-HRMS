// ============================================
// Aniston HRMS — Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// CORE MODELS
// =====================

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logo      String?
  timezone  String   @default("Asia/Kolkata")
  fiscalYear String  @default("APRIL_MARCH")
  currency  String   @default("INR")
  address   Json?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  employees    Employee[]
  departments  Department[]
  designations Designation[]
  officeLocations OfficeLocation[]
  holidays     Holiday[]
  leaveTypes   LeaveType[]
  auditLogs    AuditLog[]
  geofences    Geofence[]
  shifts       Shift[]
}

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  passwordHash   String
  role           Role       @default(EMPLOYEE)
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?
  mfaEnabled     Boolean    @default(false)
  microsoftId    String?    @unique
  authProvider   String     @default("local")
  organizationId String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee?
  auditLogs    AuditLog[]
  walkInInterviews WalkInInterviewRound[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  MANAGER
  EMPLOYEE
  INTERN
  GUEST_INTERVIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

// =====================
// EMPLOYEE
// =====================

model Employee {
  id               String         @id @default(uuid())
  employeeCode     String         @unique
  userId           String?        @unique
  firstName        String
  lastName         String
  email            String
  personalEmail    String?
  phone            String
  dateOfBirth      DateTime?
  gender           Gender
  bloodGroup       String?
  maritalStatus    String?
  avatar           String?
  address          Json?
  emergencyContact Json?

  // Employment
  departmentId     String?
  designationId    String?
  managerId        String?
  workMode         WorkMode       @default(OFFICE)
  officeLocationId String?
  joiningDate      DateTime
  probationEndDate DateTime?
  ctc              Decimal?       @db.Decimal(12, 2)
  status           EmployeeStatus @default(ACTIVE)
  organizationId   String

  // Police Verification
  policeVerificationStatus PoliceVerificationStatus @default(PENDING)
  policeVerificationDate   DateTime?

  // Exit / Offboarding
  resignationDate    DateTime?
  resignationReason  String?
  lastWorkingDate    DateTime?
  exitType           String?
  exitStatus         String?
  exitApprovedBy     String?
  exitApprovedAt     DateTime?
  exitNotes          String?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  organization   Organization     @relation(fields: [organizationId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])
  department     Department?      @relation(fields: [departmentId], references: [id])
  designation    Designation?     @relation(fields: [designationId], references: [id])
  manager        Employee?        @relation("ManagerReports", fields: [managerId], references: [id])
  directReports  Employee[]       @relation("ManagerReports")
  officeLocation OfficeLocation?  @relation(fields: [officeLocationId], references: [id])
  documents      Document[]
  attendanceRecords AttendanceRecord[]
  gpsTrailPoints    GPSTrailPoint[]
  projectSiteCheckIns ProjectSiteCheckIn[]
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
  salaryStructure   SalaryStructure?
  payrollRecords    PayrollRecord[]
  assetAssignments  AssetAssignment[]
  shiftAssignments  ShiftAssignment[]
  lifecycleEvents   EmployeeEvent[]
  tickets           Ticket[]
  activityLogs      ActivityLog[]
  agentScreenshots  AgentScreenshot[]
  exitChecklist     ExitChecklist?
  internProfile     InternProfile?
  internsMentored        InternProfile[]       @relation("InternMentor")
  salaryVisibilityRule   SalaryVisibilityRule?
  headOfDepartments      Department[]          @relation("DepartmentHead")

  @@index([organizationId, status])
  @@index([departmentId])
  @@index([managerId])
  @@index([email])
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EmployeeStatus {
  ACTIVE
  PROBATION
  NOTICE_PERIOD
  INACTIVE
  TERMINATED
  ABSCONDED
}

enum WorkMode {
  OFFICE
  HYBRID
  FIELD_SALES
  PROJECT_SITE
  REMOTE
}

model EmployeeEvent {
  id          String   @id @default(uuid())
  employeeId  String
  eventType   String   // JOINING, PROBATION_END, CONFIRMATION, PROMOTION, TRANSFER, SALARY_REVISION, WARNING, SEPARATION, REHIRE, STATUS_CHANGE
  title       String
  description String?
  eventDate   DateTime
  metadata    Json?    // e.g. { oldDepartment, newDepartment, oldDesignation, newDesignation, oldSalary, newSalary }
  createdBy   String?
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([eventDate])
}

enum PoliceVerificationStatus {
  PENDING
  INITIATED
  IN_PROGRESS
  COMPLETED
  FAILED
}

// =====================
// ORGANIZATION STRUCTURE
// =====================

model Department {
  id             String   @id @default(uuid())
  name           String
  description    String?
  headId         String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  head         Employee?    @relation(fields: [headId], references: [id], name: "DepartmentHead")
  employees    Employee[]

  @@unique([name, organizationId])
}

model Designation {
  id             String   @id @default(uuid())
  name           String
  level          Int?
  description    String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  employees    Employee[]

  @@unique([name, organizationId])
}

model OfficeLocation {
  id             String   @id @default(uuid())
  name           String
  address        String
  city           String?
  state          String?
  country        String   @default("India")
  timezone       String   @default("Asia/Kolkata")
  geofenceId     String?  @unique
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  geofence         Geofence?         @relation(fields: [geofenceId], references: [id])
  employees        Employee[]
  shiftAssignments ShiftAssignment[]
}

// =====================
// DOCUMENTS
// =====================

model Document {
  id              String         @id @default(uuid())
  employeeId      String?
  name            String
  type            DocumentType
  fileUrl         String
  thumbnailUrl    String?
  status          DocumentStatus @default(PENDING)
  ocrData         Json?
  tamperDetected  Boolean        @default(false)
  tamperDetails   String?
  expiryDate      DateTime?
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  employee Employee? @relation(fields: [employeeId], references: [id])
}

enum DocumentType {
  AADHAAR
  PAN
  PASSPORT
  VOTER_ID
  DRIVING_LICENSE
  DEGREE_CERTIFICATE
  TENTH_CERTIFICATE
  TWELFTH_CERTIFICATE
  EXPERIENCE_LETTER
  OFFER_LETTER_DOC
  RELIEVING_LETTER
  BANK_STATEMENT
  CANCELLED_CHEQUE
  SALARY_SLIP_DOC
  PHOTO
  SIGNATURE
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

// =====================
// ATTENDANCE
// =====================

model AttendanceRecord {
  id              String           @id @default(uuid())
  employeeId      String
  date            DateTime         @db.Date
  checkIn         DateTime?
  checkOut        DateTime?
  totalHours      Decimal?         @db.Decimal(5, 2)
  status          AttendanceStatus @default(ABSENT)
  workMode        WorkMode
  source          AttendanceSource @default(MANUAL_APP)
  checkInLocation Json?
  checkOutLocation Json?
  ipAddress       String?
  deviceType      String?
  notes           String?
  activeMinutes   Int              @default(0)
  activityPulses  Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  breaks   Break[]
  regularization AttendanceRegularization?

  @@unique([employeeId, date])
  @@index([date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  HOLIDAY
  WEEKEND
  ON_LEAVE
  WORK_FROM_HOME
}

enum AttendanceSource {
  GEOFENCE_AUTO
  MANUAL_APP
  MANUAL_HR
  QR_CODE
  BIOMETRIC
}

model Break {
  id               String    @id @default(uuid())
  attendanceId     String
  startTime        DateTime
  endTime          DateTime?
  type             BreakType @default(LUNCH)
  durationMinutes  Int?

  attendance AttendanceRecord @relation(fields: [attendanceId], references: [id])
}

enum BreakType {
  LUNCH
  SHORT
  PRAYER
  CUSTOM
}

model AttendanceRegularization {
  id           String   @id @default(uuid())
  attendanceId String   @unique
  reason       String
  requestedCheckIn  DateTime?
  requestedCheckOut DateTime?
  status       LeaveRequestStatus @default(PENDING)
  approvedBy   String?
  approverRemarks String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendance AttendanceRecord @relation(fields: [attendanceId], references: [id])
}

model GPSTrailPoint {
  id           String   @id @default(uuid())
  employeeId   String
  date         DateTime @db.Date
  lat          Decimal  @db.Decimal(10, 7)
  lng          Decimal  @db.Decimal(10, 7)
  accuracy     Decimal? @db.Decimal(6, 2)
  altitude     Decimal? @db.Decimal(8, 2)
  speed        Decimal? @db.Decimal(6, 2)
  heading      Decimal? @db.Decimal(5, 2)
  batteryLevel Int?
  timestamp    DateTime
  visitLabel   String?
  isVisitStop  Boolean  @default(false)
  stopDuration Int?

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, date])
}

model ProjectSiteCheckIn {
  id           String   @id @default(uuid())
  employeeId   String
  date         DateTime @db.Date
  siteName     String
  siteAddress  String?
  checkInPhoto String?
  checkInLat   Decimal? @db.Decimal(10, 7)
  checkInLng   Decimal? @db.Decimal(10, 7)
  notes        String?
  approvedBy   String?
  createdAt    DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, date])
}

model Geofence {
  id           String       @id @default(uuid())
  name         String
  type         GeofenceType @default(OFFICE)
  coordinates  Json
  radiusMeters Int?
  autoCheckIn  Boolean      @default(false)
  autoCheckOut Boolean      @default(false)
  strictMode   Boolean      @default(false)
  organizationId String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  officeLocation OfficeLocation?
}

enum GeofenceType {
  OFFICE
  CLIENT_SITE
  RESTRICTED
}

// =====================
// LEAVE MANAGEMENT
// =====================

model LeaveType {
  id             String   @id @default(uuid())
  name           String
  code           String
  defaultBalance Decimal  @db.Decimal(5, 1)
  carryForward   Boolean  @default(false)
  maxCarryForward Decimal? @db.Decimal(5, 1)
  isPaid         Boolean  @default(true)
  minDays        Decimal  @default(0.5) @db.Decimal(3, 1)
  maxDays        Decimal? @db.Decimal(5, 1)
  noticeDays     Int      @default(0)
  gender         Gender?

  // Leave policy configuration
  applicableTo       String   @default("ALL")    // "ALL", "PROBATION", "CONFIRMED"
  maxPerMonth        Int?                         // Max leaves per month (null = unlimited)
  allowWeekendAdjacent Boolean @default(true)     // Can apply adjacent to weekends
  allowSameDay       Boolean  @default(false)     // Can apply on same day (e.g. sick leave)
  probationMonths    Int      @default(3)         // Probation duration in months
  requiresApproval   Boolean  @default(true)      // Needs manager/HR approval
  isActive           Boolean  @default(true)      // Soft toggle

  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]

  @@unique([code, organizationId])
}

model LeaveBalance {
  id            String  @id @default(uuid())
  employeeId    String
  leaveTypeId   String
  year          Int
  allocated     Decimal @db.Decimal(5, 1)
  used          Decimal @default(0) @db.Decimal(5, 1)
  carriedForward Decimal @default(0) @db.Decimal(5, 1)
  pending       Decimal @default(0) @db.Decimal(5, 1)

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id            String             @id @default(uuid())
  employeeId    String
  leaveTypeId   String
  startDate     DateTime           @db.Date
  endDate       DateTime           @db.Date
  days          Decimal            @db.Decimal(4, 1)
  isHalfDay     Boolean            @default(false)
  halfDaySession String?
  reason        String
  status             LeaveRequestStatus @default(PENDING)
  approvedBy         String?
  approverRemarks    String?
  managerApprovedAt  DateTime?
  managerRemarks     String?
  attachmentUrl      String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId, status])
  @@index([startDate, endDate])
  @@index([status])
}

enum LeaveRequestStatus {
  PENDING
  MANAGER_APPROVED
  APPROVED
  REJECTED
  CANCELLED
}

model Holiday {
  id             String   @id @default(uuid())
  name           String
  date           DateTime @db.Date
  type           String   @default("PUBLIC")
  isOptional     Boolean  @default(false)
  organizationId String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([date, organizationId])
}

// =====================
// PAYROLL
// =====================

model SalaryStructure {
  id               String   @id @default(uuid())
  employeeId       String   @unique
  ctc              Decimal  @db.Decimal(12, 2)
  basic            Decimal  @db.Decimal(12, 2)
  hra              Decimal  @db.Decimal(12, 2)
  da               Decimal? @db.Decimal(12, 2)
  ta               Decimal? @db.Decimal(12, 2)
  medicalAllowance Decimal? @db.Decimal(12, 2)
  specialAllowance Decimal? @db.Decimal(12, 2)
  lta              Decimal? @db.Decimal(12, 2)
  performanceBonus Decimal? @db.Decimal(12, 2)
  pfEmployee       Decimal? @db.Decimal(12, 2)
  pfEmployer       Decimal? @db.Decimal(12, 2)
  esiEmployee      Decimal? @db.Decimal(12, 2)
  esiEmployer      Decimal? @db.Decimal(12, 2)
  professionalTax  Decimal? @db.Decimal(12, 2)
  tds              Decimal? @db.Decimal(12, 2)
  incomeTaxRegime    TaxRegime @default(NEW_REGIME)
  enabledComponents  Json?
  effectiveFrom      DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

enum TaxRegime {
  OLD_REGIME
  NEW_REGIME
}

model PayrollRun {
  id          String          @id @default(uuid())
  month       Int
  year        Int
  status      PayrollRunStatus @default(DRAFT)
  processedBy String?
  processedAt DateTime?
  totalGross  Decimal?        @db.Decimal(14, 2)
  totalNet    Decimal?        @db.Decimal(14, 2)
  totalDeductions Decimal?    @db.Decimal(14, 2)
  organizationId String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  records PayrollRecord[]

  @@unique([month, year, organizationId])
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
  LOCKED
}

model PayrollRecord {
  id             String  @id @default(uuid())
  payrollRunId   String
  employeeId     String
  grossSalary    Decimal @db.Decimal(12, 2)
  netSalary      Decimal @db.Decimal(12, 2)
  basic          Decimal @db.Decimal(12, 2)
  hra            Decimal @db.Decimal(12, 2)
  otherEarnings  Json?
  epfEmployee    Decimal? @db.Decimal(12, 2)
  epfEmployer    Decimal? @db.Decimal(12, 2)
  esiEmployee    Decimal? @db.Decimal(12, 2)
  esiEmployer    Decimal? @db.Decimal(12, 2)
  professionalTax Decimal? @db.Decimal(12, 2)
  tds            Decimal? @db.Decimal(12, 2)
  otherDeductions Json?
  lopDays        Int      @default(0)
  lopDeduction   Decimal? @db.Decimal(12, 2)
  workingDays    Int
  presentDays    Int
  createdAt      DateTime @default(now())

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])
}

// =====================
// RECRUITMENT
// =====================

model JobOpening {
  id              String    @id @default(uuid())
  title           String
  department      String
  location        String
  type            JobType   @default(FULL_TIME)
  experience      String?
  salaryRange     Json?
  description     String
  requirements    String[]
  openings        Int       @default(1)
  status          JobStatus @default(DRAFT)
  postedBy        String
  approvedBy      String?
  publishToNaukri Boolean   @default(false)
  publishToWebsite Boolean  @default(true)
  organizationId  String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  closedAt        DateTime?

  applications      Application[]
  walkIns            WalkInCandidate[]
  bulkResumeUploads  BulkResumeUpload[]
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  RESEARCH
}

enum JobStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
}

model Application {
  id              String            @id @default(uuid())
  jobOpeningId    String
  candidateName   String
  email           String
  phone           String
  resumeUrl       String
  coverLetter     String?
  source          ApplicationSource @default(PORTAL)
  status          ApplicationStatus @default(APPLIED)
  currentStage    Int               @default(1)
  aiScore         Decimal?          @db.Decimal(5, 2)
  aiScoreDetails  Json?
  isIntern        Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  jobOpening     JobOpening       @relation(fields: [jobOpeningId], references: [id])
  interviewScores InterviewScore[]
  offerLetter    OfferLetter?
}

enum ApplicationSource {
  PORTAL
  NAUKRI
  LINKEDIN
  REFERENCE
  CAMPUS
  WALK_IN
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  ASSESSMENT
  INTERVIEW_1
  INTERVIEW_2
  HR_ROUND
  FINAL_ROUND
  OFFER
  OFFER_ACCEPTED
  JOINED
  REJECTED
  WITHDRAWN
}

model InterviewScore {
  id                 String  @id @default(uuid())
  applicationId      String
  round              Int
  interviewerId      String?
  communicationScore Decimal? @db.Decimal(3, 1)
  technicalScore     Decimal? @db.Decimal(3, 1)
  problemSolving     Decimal? @db.Decimal(3, 1)
  culturalFit        Decimal? @db.Decimal(3, 1)
  overallScore       Decimal? @db.Decimal(3, 1)
  notes              String?
  teamsRecordingUrl  String?
  aiAnalysis         Json?
  createdAt          DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model OfferLetter {
  id              String      @id @default(uuid())
  applicationId   String      @unique
  candidateEmail  String
  ctc             Decimal     @db.Decimal(12, 2)
  basicSalary     Decimal     @db.Decimal(12, 2)
  joiningDate     DateTime?
  status          OfferStatus @default(DRAFT)
  pdfUrl          String?
  sentAt          DateTime?
  respondedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

enum OfferStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  NEGOTIATING
  EXPIRED
}

// =====================
// BULK RESUME UPLOADS
// =====================

enum BulkUploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ResumeItemStatus {
  PENDING
  PROCESSING
  SCORED
  FAILED
}

model BulkResumeUpload {
  id             String           @id @default(uuid())
  jobOpeningId   String
  uploadedBy     String
  totalFiles     Int              @default(0)
  processedFiles Int              @default(0)
  status         BulkUploadStatus @default(PENDING)
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  jobOpening JobOpening       @relation(fields: [jobOpeningId], references: [id])
  items      BulkResumeItem[]
}

model BulkResumeItem {
  id             String           @id @default(uuid())
  bulkUploadId   String
  fileName       String
  fileUrl        String
  candidateName  String?
  email          String?
  phone          String?
  aiScore        Decimal?         @db.Decimal(5, 2)
  aiScoreDetails Json?
  applicationId  String?
  status         ResumeItemStatus @default(PENDING)
  errorMessage   String?
  createdAt      DateTime         @default(now())

  bulkUpload BulkResumeUpload @relation(fields: [bulkUploadId], references: [id])
}

// =====================
// CANDIDATE PROFILES
// =====================

model CandidateProfile {
  id             String   @id @default(uuid())
  candidateCode  String   @unique
  applicationId  String?  @unique
  walkInId       String?  @unique
  fullName       String
  email          String
  phone          String?
  resumeUrl      String?
  manualCvUpload Boolean  @default(false)
  uploadedBy     String?
  notes          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// =====================
// WHATSAPP INTEGRATION
// =====================

enum WaTemplateType {
  JOB_LINK
  ONBOARDING_INVITE
  OFFER_LETTER
  LEAVE_APPROVED
  GENERAL
}

enum WaMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model WhatsAppSession {
  id             String    @id @default(uuid())
  sessionName    String    @unique
  qrCode         String?
  isConnected    Boolean   @default(false)
  phoneNumber    String?
  lastPing       DateTime?
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WhatsAppMessage {
  id             String          @id @default(uuid())
  sessionId      String
  to             String
  message        String
  templateType   WaTemplateType?
  referenceId    String?
  referenceType  String?
  status         WaMessageStatus @default(PENDING)
  sentAt         DateTime?
  deliveredAt    DateTime?
  error          String?
  organizationId String
  createdAt      DateTime        @default(now())
}

// =====================
// ASSETS
// =====================

model Asset {
  id             String         @id @default(uuid())
  name           String
  assetCode      String         @unique
  category       AssetCategory
  brand          String?
  modelNumber    String?
  serialNumber   String?
  status         AssetStatus    @default(AVAILABLE)
  condition      AssetCondition @default(GOOD)
  purchaseDate   DateTime?
  purchaseCost   Decimal?       @db.Decimal(12, 2)
  warrantyExpiry DateTime?
  vendor         String?
  location       String?
  notes          String?
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  assignments        AssetAssignment[]
  tickets            Ticket[]
  exitChecklistItems ExitChecklistItem[]
}

enum AssetCategory {
  LAPTOP
  MOBILE
  SIM_CARD
  ACCESS_CARD
  VISITING_CARD
  MONITOR
  OTHER
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  DAMAGED
  LOST
}

model AssetAssignment {
  id              String          @id @default(uuid())
  assetId         String
  employeeId      String
  assignedBy      String
  assignedAt      DateTime        @default(now())
  returnedAt      DateTime?
  condition       String?
  returnCondition AssetCondition?
  returnNotes     String?
  notes           String?

  asset    Asset    @relation(fields: [assetId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

model ExitChecklist {
  id                        String    @id @default(uuid())
  employeeId                String    @unique
  assetsClearedAt           DateTime?
  assetsApprovedBy          String?
  knowledgeTransferDone     Boolean   @default(false)
  accessRevokedAt           DateTime?
  finalSettlementDone       Boolean   @default(false)
  salaryProcessingUnblocked Boolean   @default(false)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  employee Employee            @relation(fields: [employeeId], references: [id])
  items    ExitChecklistItem[]
}

model ExitChecklistItem {
  id          String    @id @default(uuid())
  checklistId String
  assetId     String?
  itemName    String
  isReturned  Boolean   @default(false)
  returnedAt  DateTime?
  approvedBy  String?
  notes       String?

  checklist ExitChecklist @relation(fields: [checklistId], references: [id])
  asset     Asset?        @relation(fields: [assetId], references: [id])
}

// =====================
// INTERN PROFILES
// =====================

model InternProfile {
  id                  String                   @id @default(uuid())
  employeeId          String                   @unique
  collegeUniversity   String?
  course              String?
  specialization      String?
  internshipStartDate DateTime
  internshipEndDate   DateTime
  stipend             Decimal?                 @db.Decimal(10, 2)
  mentorId            String?
  projectTitle        String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  employee            Employee                 @relation(fields: [employeeId], references: [id])
  mentor              Employee?                @relation("InternMentor", fields: [mentorId], references: [id])
  achievementLetters  InternAchievementLetter[]
}

model InternAchievementLetter {
  id              String        @id @default(uuid())
  internProfileId String
  title           String
  description     String
  issuedBy        String
  issuedAt        DateTime      @default(now())
  pdfUrl          String?

  internProfile   InternProfile @relation(fields: [internProfileId], references: [id])
}

// =====================
// SALARY VISIBILITY
// =====================

model SalaryVisibilityRule {
  id               String   @id @default(uuid())
  employeeId       String   @unique
  visibleToHR      Boolean  @default(true)
  visibleToManager Boolean  @default(false)
  hiddenReason     String?
  setBy            String
  updatedAt        DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

// =====================
// POLICIES & ANNOUNCEMENTS
// =====================

model Policy {
  id             String         @id @default(uuid())
  title          String
  category       PolicyCategory
  content        String
  version        Int            @default(1)
  isActive       Boolean        @default(true)
  targetAudience Json?
  attachments    String[]
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  acknowledgments PolicyAcknowledgment[]
}

enum PolicyCategory {
  HR_GENERAL
  LEAVE
  HYBRID
  WORK_MANAGEMENT
  ESCALATION
  IT
  CODE_OF_CONDUCT
  HEALTH_SAFETY
}

model PolicyAcknowledgment {
  id         String   @id @default(uuid())
  policyId   String
  employeeId String
  acknowledgedAt DateTime @default(now())

  policy Policy @relation(fields: [policyId], references: [id])

  @@unique([policyId, employeeId])
}

model Announcement {
  id             String   @id @default(uuid())
  title          String
  content        String
  priority       String   @default("NORMAL")
  targetDepartments String[]
  targetRoles    String[]
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdBy      String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// =====================
// AUDIT LOG
// =====================

model AuditLog {
  id             String   @id @default(uuid())
  userId         String
  entity         String
  entityId       String
  action         String
  oldValue       Json?
  newValue       Json?
  ipAddress      String?
  organizationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// =====================
// PERFORMANCE
// =====================

model ReviewCycle {
  id             String   @id @default(uuid())
  name           String
  type           String   @default("QUARTERLY")
  startDate      DateTime @db.Date
  endDate        DateTime @db.Date
  status         String   @default("DRAFT")
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  goals   Goal[]
  reviews PerformanceReview[]
}

model Goal {
  id             String   @id @default(uuid())
  employeeId     String
  reviewCycleId  String?
  title          String
  description    String?
  category       String   @default("INDIVIDUAL")
  targetValue    Decimal? @db.Decimal(10, 2)
  currentValue   Decimal? @db.Decimal(10, 2)
  unit           String?
  weight         Int      @default(100)
  status         String   @default("NOT_STARTED")
  dueDate        DateTime? @db.Date
  completedAt    DateTime?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reviewCycle ReviewCycle? @relation(fields: [reviewCycleId], references: [id])

  @@index([employeeId])
}

model PerformanceReview {
  id              String   @id @default(uuid())
  employeeId      String
  reviewCycleId   String
  reviewerId      String
  selfRating      Decimal? @db.Decimal(3, 1)
  selfComments    String?
  managerRating   Decimal? @db.Decimal(3, 1)
  managerComments String?
  overallRating   Decimal? @db.Decimal(3, 1)
  strengths       String[]
  improvements    String[]
  status          String   @default("PENDING")
  submittedAt     DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reviewCycle ReviewCycle @relation(fields: [reviewCycleId], references: [id])

  @@unique([employeeId, reviewCycleId])
}

// =====================
// SOCIAL WALL
// =====================

model SocialPost {
  id             String   @id @default(uuid())
  authorId       String
  content        String
  imageUrl       String?
  postType       String   @default("GENERAL")
  likesCount     Int      @default(0)
  commentsCount  Int      @default(0)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  comments SocialComment[]
  likes    SocialLike[]
}

model SocialComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model SocialLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// =====================
// HELPDESK
// =====================

model Ticket {
  id             String   @id @default(uuid())
  ticketCode     String   @unique
  employeeId     String
  category       String
  subject        String
  description    String
  priority       String   @default("MEDIUM")
  status         String   @default("OPEN")
  assignedTo     String?
  resolvedAt     DateTime?
  resolution     String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assetId        String?

  employee Employee @relation(fields: [employeeId], references: [id])
  asset    Asset?   @relation(fields: [assetId], references: [id])
  comments TicketComment[]
}

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  content   String
  isInternal Boolean @default(false)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// =====================
// SHIFTS & ROSTERS
// =====================

enum ShiftType {
  OFFICE
  HYBRID
  FIELD
}

model Shift {
  id                      String    @id @default(uuid())
  name                    String
  code                    String
  shiftType               ShiftType @default(OFFICE)
  startTime               String    // "09:00" (HH:mm)
  endTime                 String    // "18:00"
  graceMinutes            Int       @default(15)
  halfDayHours            Decimal   @db.Decimal(4, 2) @default(4)
  fullDayHours            Decimal   @db.Decimal(4, 2) @default(8)
  trackingIntervalMinutes Int?      // FIELD shifts only (15-480 min)
  isDefault               Boolean   @default(false)
  isActive                Boolean   @default(true)
  organizationId          String
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  assignments  ShiftAssignment[]

  @@unique([code, organizationId])
}

model ShiftAssignment {
  id         String    @id @default(uuid())
  employeeId String
  shiftId    String
  locationId String?
  startDate  DateTime  @db.Date
  endDate    DateTime? @db.Date
  assignedBy String
  createdAt  DateTime  @default(now())

  employee Employee        @relation(fields: [employeeId], references: [id])
  shift    Shift           @relation(fields: [shiftId], references: [id])
  location OfficeLocation? @relation(fields: [locationId], references: [id])

  @@index([employeeId, startDate])
}

// =====================
// WALK-IN CANDIDATES
// =====================

model WalkInCandidate {
  id              String       @id @default(uuid())
  tokenNumber     String       @unique  // "WALK-IN-2026-0001"
  jobOpeningId    String?
  fullName        String
  email           String
  phone           String
  city            String?

  // KYC Documents
  aadhaarFrontUrl String?
  aadhaarBackUrl  String?
  panCardUrl      String?
  selfieUrl       String?
  aadhaarNumber   String?      // Masked: XXXX-XXXX-1234
  panNumber       String?      // Masked: ABCDE1234F

  // OCR Verification
  ocrVerifiedName    String?
  ocrVerifiedDob     DateTime?
  ocrVerifiedAddress String?
  tamperDetected     Boolean   @default(false)
  tamperDetails      String?

  // Professional Details
  qualification    String?
  fieldOfStudy     String?
  experienceYears  Int         @default(0)
  experienceMonths Int         @default(0)
  isFresher        Boolean     @default(true)
  currentCompany   String?
  currentCtc       Decimal?    @db.Decimal(12, 2)
  expectedCtc      Decimal?    @db.Decimal(12, 2)
  noticePeriod     String?
  skills           String[]
  aboutMe          String?
  resumeUrl        String?

  // AI Scoring
  aiScore          Decimal?    @db.Decimal(5, 2)
  aiScoreDetails   Json?

  // Status
  registrationDate DateTime    @default(now())
  status           WalkInStatus @default(WAITING)
  currentRound     Int          @default(0)
  totalRounds      Int          @default(1)
  convertedToApp   Boolean     @default(false)
  applicationId    String?
  hrNotes          String?
  organizationId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobOpening       JobOpening?        @relation(fields: [jobOpeningId], references: [id])
  interviewRounds  WalkInInterviewRound[]

  @@index([organizationId, registrationDate])
  @@index([status])
}

model WalkInInterviewRound {
  id              String   @id @default(uuid())
  walkInId        String
  roundNumber     Int
  roundName       String   // "HR Screening", "Technical Round", "Manager Round", etc.
  interviewerName String?
  interviewerId   String?
  scheduledAt     DateTime?
  completedAt     DateTime?
  status          InterviewRoundStatus @default(PENDING)

  // Scoring (1-10)
  communication   Int?
  technical       Int?
  problemSolving  Int?
  culturalFit     Int?
  overallScore    Int?
  remarks         String?
  result          InterviewRoundResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  walkIn      WalkInCandidate @relation(fields: [walkInId], references: [id], onDelete: Cascade)
  interviewer User?           @relation(fields: [interviewerId], references: [id])

  @@unique([walkInId, roundNumber])
  @@index([walkInId])
}

enum InterviewRoundStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InterviewRoundResult {
  PASSED
  FAILED
  ON_HOLD
}

enum WalkInStatus {
  WAITING
  IN_INTERVIEW
  ON_HOLD
  SELECTED
  REJECTED
  COMPLETED
  NO_SHOW
}

// =====================
// DESKTOP AGENT TRACKING
// =====================

model ActivityLog {
  id              String   @id @default(uuid())
  employeeId      String
  date            DateTime @db.Date
  timestamp       DateTime
  activeApp       String?
  activeWindow    String?
  activeUrl       String?
  category        String?  // PRODUCTIVE, NEUTRAL, UNPRODUCTIVE
  durationSeconds Int      @default(0)
  idleSeconds     Int      @default(0)
  keystrokes      Int      @default(0)
  mouseClicks     Int      @default(0)
  mouseDistance    Int      @default(0)
  organizationId  String
  createdAt       DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, date])
  @@index([organizationId, date])
}

model AgentScreenshot {
  id             String   @id @default(uuid())
  employeeId     String
  date           DateTime @db.Date
  timestamp      DateTime
  imageUrl       String
  activeApp      String?
  activeWindow   String?
  organizationId String
  createdAt      DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, date])
}
