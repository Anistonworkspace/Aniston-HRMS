model TaskIntegrationHealthLog {
  id               String   @id @default(uuid())
  organizationId   String
  provider         String
  status           String
  tokenValid       Boolean  @default(true)
  mappingErrors    Int      @default(0)
  staleSyncFlag    Boolean  @default(false)
  failedCallsCount Int      @default(0)
  responseTimeMs   Int?
  notes            String?
  checkedAt        DateTime @default(now())

  @@index([organizationId, checkedAt])
}

// =====================
// LEAVE HANDOVER & AUDIT TRAIL
// =====================

model LeaveHandover {
  id               String   @id @default(uuid())
  leaveRequestId   String
  backupEmployeeId String
  taskExternalId   String?
  taskTitle        String?
  handoverNote     String
  organizationId   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  leaveRequest     LeaveRequest @relation(fields: [leaveRequestId], references: [id])

  @@index([leaveRequestId])
  @@index([backupEmployeeId])
  @@index([organizationId])
}

model LeaveApprovalDecision {
  id               String     @id @default(uuid())
  leaveRequestId   String
  actorId          String
  actorRole        String
  action           String
  comment          String?
  conditionNote    String?
  riskLevelAtTime  RiskLevel?
  organizationId   String
  createdAt        DateTime   @default(now())

  leaveRequest     LeaveRequest @relation(fields: [leaveRequestId], references: [id])

  @@index([leaveRequestId])
  @@index([actorId])
  @@index([organizationId])
}

model LeaveNotificationLog {
  id               String   @id @default(uuid())
  leaveRequestId   String
  recipientId      String
  channel          String   @default("BOTH")
  templateName     String
  payload          Json?
  status           String   @default("SENT")
  errorMessage     String?
  organizationId   String
  sentAt           DateTime @default(now())

  leaveRequest     LeaveRequest @relation(fields: [leaveRequestId], references: [id])

  @@index([leaveRequestId])
  @@index([recipientId])
  @@index([organizationId])
}

// ══════════════════════════════════════════════════════════
// Phase 2B Models
// ══════════════════════════════════════════════════════════

model DeviceSession {
  id           String   @id @default(uuid())
  userId       String
  deviceId     String
  deviceType   String   // 'mobile' or 'desktop'
  userAgent    String?
  lastActiveAt DateTime @default(now())
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceType])
  @@index([userId])
}

model UserMFA {
  id          String    @id @default(uuid())
  userId      String    @unique
  secret      String    // TOTP secret (AES-256 encrypted)
  isEnabled   Boolean   @default(false)
  backupCodes String[]  // one-time backup codes
  enabledAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WhatsAppOtp {
  id         String   @id @default(uuid())
  employeeId String
  phone      String
  otp        String
  expiresAt  DateTime
  verified   Boolean  @default(false)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model LocationVisit {
  id              String           @id @default(uuid())
  attendanceId    String
  latitude        Float
  longitude       Float
  arrivalTime     DateTime
  departureTime   DateTime
  durationMinutes Int
  pointCount      Int              @default(1)
  createdAt       DateTime         @default(now())
  attendance      AttendanceRecord @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
}

model LeavePolicy {
  id             String            @id @default(uuid())
  name           String
  description    String?
  organizationId String
  isDefault      Boolean           @default(false)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id])
  rules          LeavePolicyRule[]
  employees      Employee[]

  @@index([organizationId])
}

model LeavePolicyRule {
  id          String      @id @default(uuid())
  policyId    String
  leaveTypeId String
  daysAllowed Float
  isAllowed   Boolean     @default(true)
  policy      LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  leaveType   LeaveType   @relation(fields: [leaveTypeId], references: [id])

  @@unique([policyId, leaveTypeId])
}

// ══════════════════════════════════════════════════════════
// Attendance Enhancement Models (Priority 1 + Priority 2)
// ══════════════════════════════════════════════════════════

model AttendancePolicy {
  id                    String   @id @default(uuid())
  organizationId        String   @unique
  // Late penalty
  lateGraceMinutes      Int      @default(15)
  lateHalfDayAfterMins  Int      @default(120)
  latePenaltyEnabled    Boolean  @default(false)
  latePenaltyPerCount   Int      @default(3)
  // Half-day cutoff
  halfDayMinHours       Decimal  @db.Decimal(4, 2) @default(4)
  fullDayMinHours       Decimal  @db.Decimal(4, 2) @default(8)
  // Overtime
  otEnabled             Boolean  @default(false)
  otThresholdMinutes    Int      @default(30)
  otRateMultiplier      Decimal  @db.Decimal(3, 2) @default(1.5)
  otMaxHoursPerDay      Decimal  @db.Decimal(4, 2) @default(4)
  // Comp-off
  compOffEnabled        Boolean  @default(false)
  compOffMinOTHours     Decimal  @db.Decimal(4, 2) @default(4)
  compOffExpiryDays     Int      @default(30)
  // Week off days (0=Sun, 1=Mon, ..., 6=Sat)
  weekOffDays           Int[]    @default([0])
  // Auto-absent
  autoAbsentAfterHours  Int      @default(4)
  // Sunday / special-day working
  sundayWorkEnabled     Boolean  @default(false)    // Allow selected employees to work on Sunday
  sundayPayMultiplier   Decimal  @db.Decimal(3, 2) @default(2.0)  // e.g. 2.0 = double pay
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model OvertimeRequest {
  id              String         @id @default(uuid())
  employeeId      String
  date            DateTime       @db.Date
  plannedHours    Decimal        @db.Decimal(4, 2)
  actualHours     Decimal?       @db.Decimal(4, 2)
  reason          String
  status          OvertimeStatus @default(PENDING)
  approvedBy      String?
  approverRemarks String?
  approvedAt      DateTime?
  attendanceId    String?
  organizationId  String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  employee   Employee          @relation(fields: [employeeId], references: [id])
  attendance AttendanceRecord? @relation(fields: [attendanceId], references: [id])

  @@unique([employeeId, date])
  @@index([organizationId, date])
  @@index([status])
}

enum OvertimeStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

model ShiftRotationPattern {
  id             String    @id @default(uuid())
  name           String
  rotationWeeks  Int       @default(1)
  pattern        Json
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  @@index([organizationId])
}

// =====================
// COMPANY BRANDING
// =====================

model CompanyBranding {
  id             String   @id @default(uuid())
  logoUrl        String?
  signatureUrl   String?
  stampUrl       String?
  companyName    String?
  companyAddress String?
  organizationId String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

// =====================
// LETTER MANAGEMENT
// =====================

model LetterTemplate {
  id             String   @id @default(uuid())
  name           String
  slug           String
  description    String?
  previewUrl     String?
  layout         Json
  isActive       Boolean  @default(true)
  isDefault      Boolean  @default(false)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  letters      Letter[]
  @@index([organizationId])
  @@unique([slug, organizationId])
}

model Letter {
  id             String      @id @default(uuid())
  type           LetterType
  title          String
  content        Json
  filePath       String?
  templateId     String?
  issuedById     String
  organizationId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  template    LetterTemplate? @relation(fields: [templateId], references: [id])
  issuedBy    User            @relation(fields: [issuedById], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id])
  assignments LetterAssignment[]

  @@index([organizationId])
  @@index([issuedById])
  @@index([type])
}

model LetterAssignment {
  id              String    @id @default(uuid())
  letterId        String
  employeeId      String
  downloadAllowed Boolean   @default(false)
  viewedAt        DateTime?
  downloadedAt    DateTime?
  organizationId  String
  createdAt       DateTime  @default(now())

  letter   Letter   @relation(fields: [letterId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([letterId, employeeId])
  @@index([employeeId])
  @@index([organizationId])
}

enum LetterType {
  OFFER_LETTER
  JOINING_LETTER
  EXPERIENCE_LETTER
  RELIEVING_LETTER
  SALARY_SLIP_LETTER
  PROMOTION_LETTER
  WARNING_LETTER
  APPRECIATION_LETTER
  CUSTOM
}

// =====================
// EMPLOYEE DELETION REQUESTS
// =====================

enum DeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model EmployeeDeletionRequest {
  id              String                @id @default(uuid())
  organizationId  String
  // Nullable FK: set to null after employee is permanently removed
  employeeId      String?
  // Snapshot fields — preserved even after deletion for audit trail
  employeeName    String
  employeeCode    String
  employeeEmail   String
  // Requestor
  requestedById   String
  requestedByName String
  requestedByRole String
  reason          String
  notes           String?
  status          DeletionRequestStatus @default(PENDING)
  // Review
  reviewedById    String?
  reviewedByName  String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  employee     Employee?     @relation("EmployeeDeletionRequests", fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([employeeId])
  @@index([status])
}

// =====================
// BACKUP (DATABASE + FILES)
// =====================

enum BackupType {
  MANUAL
  SCHEDULED
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  DELETED
}

enum BackupCategory {
  DATABASE
  FILES
}

model DatabaseBackup {
  id             String         @id @default(uuid())
  filename       String         // e.g. db_backup_2026-04-09T10-30-00.sql.gz OR files_backup_*.tar.gz
  filePath       String         // relative path under uploads/backups/
  sizeBytes      BigInt         @default(0)
  category       BackupCategory @default(DATABASE) // DATABASE = pg_dump gzip; FILES = uploads tar.gz
  type           BackupType     @default(MANUAL)
  status         BackupStatus   @default(PENDING)
  notes          String?        // failure reason or admin note
  createdById    String?        // null for scheduled backups
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?      // soft-delete for history tracking

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([organizationId, category])
}
