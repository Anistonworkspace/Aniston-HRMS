// ============================================
// Aniston HRMS — Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// CORE MODELS
// =====================

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logo      String?
  timezone  String   @default("Asia/Kolkata")
  fiscalYear String  @default("APRIL_MARCH")
  currency  String   @default("INR")
  address   Json?
  settings  Json?
  adminNotificationEmail String?
  payrollEmail           String?  // Accounts department email for payroll reports
  workingDays            String   @default("1,2,3,4,5,6") // Comma-separated day numbers: 0=Sun,1=Mon,...,6=Sat
  // Payroll statutory defaults — used when per-employee config is null
  defaultPTState         String    @default("MAHARASHTRA") // State code for Professional Tax slabs
  defaultTaxRegime       TaxRegime @default(NEW_REGIME)    // Income tax regime default for new employees
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  employees    Employee[]
  departments  Department[]
  designations Designation[]
  officeLocations OfficeLocation[]
  holidays     Holiday[]
  leaveTypes   LeaveType[]
  auditLogs    AuditLog[]
  geofences    Geofence[]
  shifts       Shift[]
  leavePolicies LeavePolicy[]
  attendancePolicy AttendancePolicy?
  shiftRotationPatterns ShiftRotationPattern[]
  policies          Policy[]
  companyBranding   CompanyBranding?
  letterTemplates   LetterTemplate[]
  letters           Letter[]
  letterAssignments LetterAssignment[]
  databaseBackups   DatabaseBackup[]
  deletionRequests         EmployeeDeletionRequest[]
  payrollDeletionRequests  PayrollDeletionRequest[]
}

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  passwordHash   String
  role           Role       @default(EMPLOYEE)
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?
  mfaEnabled     Boolean    @default(false)
  microsoftId    String?    @unique
  authProvider   String     @default("local")
  organizationId String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee?
  auditLogs    AuditLog[]
  walkInInterviews WalkInInterviewRound[]
  issuedLetters Letter[]
  // Phase 2B
  deviceSessions DeviceSession[]
  mfa            UserMFA?
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  MANAGER
  EMPLOYEE
  INTERN
  GUEST_INTERVIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

// =====================
// EMPLOYEE
// =====================

model Employee {
  id               String         @id @default(uuid())
  employeeCode     String         @unique
  userId           String?        @unique
  firstName        String
  lastName         String
  email            String
  personalEmail    String?
  phone            String
  dateOfBirth      DateTime?
  gender           Gender
  bloodGroup       String?
  maritalStatus    String?
  avatar           String?
  address          Json?
  emergencyContact Json?
  fatherName       String?

  // Bank Details (salary account)
  bankAccountNumber   String?
  bankName            String?
  ifscCode            String?
  accountHolderName   String?
  accountType         String?       // SAVINGS / CURRENT

  // KYC extracted (auto-filled from verified documents)
  panNumber        String?          // From verified PAN document OCR
  aadhaarEncrypted String?          // AES-256-GCM encrypted, from verified Aadhaar OCR

  // Employment
  departmentId     String?
  designationId    String?
  managerId        String?
  workMode         WorkMode       @default(OFFICE)
  officeLocationId String?
  joiningDate      DateTime
  onboardingDate   DateTime?  // Date employee was first registered in this HRMS (auto-set on creation). Used for payroll pro-ration. Differs from joiningDate (contractual employment date).
  probationEndDate DateTime?
  ctc              Decimal?       @db.Decimal(12, 2)
  status           EmployeeStatus @default(ONBOARDING)
  organizationId   String

  // Police Verification
  policeVerificationStatus PoliceVerificationStatus @default(PENDING)
  policeVerificationDate   DateTime?

  // Onboarding
  onboardingComplete Boolean   @default(false)

  // Agent pairing (permanent code for desktop activity agent)
  agentPairingCode   String?   @unique
  agentPairedAt      DateTime?

  // System accounts (superadmin, hr, admin) — not counted as employees
  isSystemAccount    Boolean   @default(false)

  // Exit / Offboarding
  resignationDate    DateTime?
  resignationReason  String?
  lastWorkingDate    DateTime?
  exitType           String?
  exitStatus         String?
  exitApprovedBy     String?
  exitApprovedAt     DateTime?
  exitNotes          String?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  organization   Organization     @relation(fields: [organizationId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])
  department     Department?      @relation(fields: [departmentId], references: [id])
  designation    Designation?     @relation(fields: [designationId], references: [id])
  manager        Employee?        @relation("ManagerReports", fields: [managerId], references: [id])
  directReports  Employee[]       @relation("ManagerReports")
  officeLocation OfficeLocation?  @relation(fields: [officeLocationId], references: [id])
  documents      Document[]
  attendanceRecords AttendanceRecord[]
  gpsTrailPoints    GPSTrailPoint[]
  projectSiteCheckIns ProjectSiteCheckIn[]
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
  salaryStructure   SalaryStructure?
  salaryHistory     SalaryHistory[]
  payrollRecords    PayrollRecord[]
  assetAssignments  AssetAssignment[]
  shiftAssignments  ShiftAssignment[]
  lifecycleEvents   EmployeeEvent[]
  tickets           Ticket[]
  activityLogs      ActivityLog[]
  agentScreenshots  AgentScreenshot[]
  exitChecklist     ExitChecklist?
  internProfile     InternProfile?
  internsMentored        InternProfile[]       @relation("InternMentor")
  salaryVisibilityRule   SalaryVisibilityRule?
  documentGate           OnboardingDocumentGate?
  exitAccessConfig       ExitAccessConfig?
  permissionOverride     PermissionOverride?
  headOfDepartments      Department[]          @relation("DepartmentHead")
  hybridSchedule         HybridSchedule?
  // Sunday / special-day work override
  allowSundayWork        Boolean               @default(false)  // Employee-level override for Sunday attendance

  // Payroll statutory exemptions (per-employee overrides)
  epfExempt              Boolean               @default(false) // Skip EPF deduction (e.g. interns, contract workers)
  esiExempt              Boolean               @default(false) // Skip ESI deduction (permanent exemption)
  ptExempt               Boolean               @default(false) // Skip Professional Tax (e.g. senior mgmt in exempt states)
  incomeTaxRegimeChoice  TaxRegime?                            // Employee's chosen regime; overrides salary structure setting

  // Phase 2B
  isPhoneVerified        Boolean               @default(false)
  leavePolicyId          String?
  leavePolicy            LeavePolicy?          @relation(fields: [leavePolicyId], references: [id])
  whatsAppOtps           WhatsAppOtp[]
  overtimeRequests       OvertimeRequest[]
  attendanceAnomalies    AttendanceAnomaly[]
  attendanceRegularizations AttendanceRegularization[]
  payrollAdjustments        PayrollAdjustment[]
  letterAssignments         LetterAssignment[]
  deletionRequests          EmployeeDeletionRequest[] @relation("EmployeeDeletionRequests")

  @@index([organizationId, status])
  @@index([departmentId])
  @@index([managerId])
  @@index([email])
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EmployeeStatus {
  ONBOARDING
  ACTIVE
  PROBATION
  INTERN
  NOTICE_PERIOD
  SUSPENDED
  INACTIVE
  TERMINATED
  ABSCONDED
}

enum WorkMode {
  OFFICE
  HYBRID
  FIELD_SALES
  PROJECT_SITE
  REMOTE
}

model EmployeeEvent {
  id          String   @id @default(uuid())
  employeeId  String
  eventType   String   // JOINING, PROBATION_END, CONFIRMATION, PROMOTION, TRANSFER, SALARY_REVISION, WARNING, SEPARATION, REHIRE, STATUS_CHANGE
  title       String
  description String?
  eventDate   DateTime
  metadata    Json?    // e.g. { oldDepartment, newDepartment, oldDesignation, newDesignation, oldSalary, newSalary }
  createdBy   String?
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([eventDate])
}

enum PoliceVerificationStatus {
  PENDING
  INITIATED
  IN_PROGRESS
  COMPLETED
  FAILED
}

// =====================
// ORGANIZATION STRUCTURE
// =====================

model Department {
  id               String   @id @default(uuid())
  name             String
  slug             String?
  code             String?
  description      String?
  headId           String?
  parentDepartmentId String?
  isActive         Boolean  @default(true)
  createdById      String?
  updatedById      String?
  organizationId   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  organization     Organization  @relation(fields: [organizationId], references: [id])
  head             Employee?     @relation(fields: [headId], references: [id], name: "DepartmentHead")
  parentDepartment Department?   @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments Department[]  @relation("DepartmentHierarchy")
  employees        Employee[]
  designations     Designation[]

  @@unique([name, organizationId])
  @@unique([code, organizationId])
  @@index([organizationId, isActive])
  @@index([slug, organizationId])
}

model Designation {
  id             String   @id @default(uuid())
  name           String
  slug           String?
  code           String?
  level          Int?
  levelBand      String?
  description    String?
  departmentId   String?
  isActive       Boolean  @default(true)
  createdById    String?
  updatedById    String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  department   Department?  @relation(fields: [departmentId], references: [id])
  employees    Employee[]

  @@unique([name, organizationId])
  @@unique([code, organizationId])
  @@index([organizationId, isActive])
  @@index([departmentId])
}

model OfficeLocation {
  id             String   @id @default(uuid())
  name           String
  address        String
  city           String?
  state          String?
  country        String   @default("India")
  timezone       String   @default("Asia/Kolkata")
  geofenceId     String?  @unique
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  geofence         Geofence?         @relation(fields: [geofenceId], references: [id])
  employees        Employee[]
  shiftAssignments ShiftAssignment[]
}

// =====================
// DOCUMENTS
// =====================

model Document {
  id              String         @id @default(uuid())
  employeeId      String?
  name            String
  type            DocumentType
  fileUrl         String
  thumbnailUrl    String?
  status          DocumentStatus @default(PENDING)
  ocrData         Json?
  tamperDetected  Boolean        @default(false)
  tamperDetails   String?
  expiryDate      DateTime?
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectionReason String?
  issuedBy        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  employee        Employee?              @relation(fields: [employeeId], references: [id])
  ocrVerification DocumentOcrVerification?
}

model DocumentOcrVerification {
  id                    String    @id @default(uuid())
  documentId            String    @unique
  organizationId        String

  // Raw OCR
  rawText               String?
  detectedType          String?
  confidence            Float     @default(0)

  // Extracted fields (editable by HR)
  extractedName         String?
  extractedDob          String?
  extractedFatherName   String?
  extractedMotherName   String?
  extractedDocNumber    String?
  extractedGender       String?
  extractedAddress      String?

  // Image quality
  isScreenshot          Boolean   @default(false)
  isOriginalScan        Boolean   @default(true)
  resolutionQuality     String?   // LOW, MEDIUM, HIGH
  tamperingIndicators   Json?     // string[]

  // Format validation
  formatValid           Boolean?
  formatErrors          Json?

  // Cross-validation
  crossValidationStatus String?   // PASS, FAIL, PARTIAL, PENDING
  crossValidationDetails Json?

  // LLM extraction (parallel to OCR)
  llmExtractedData      Json?        // LLM extraction result (parallel to OCR)
  llmConfidence         Float?       // LLM confidence score

  // Processing mode tracking
  processingMode        String?      // python_advanced | node_fallback | manual_review
  extractionSource      String?      // tesseract | llm | python | node_fallback

  // Suspicion scoring
  suspicionScore        Float        @default(0)
  suspicionFlags        Json?        // string[] of suspicion reasons

  // HR review
  hrReviewedBy          String?
  hrReviewedAt          DateTime?
  hrNotes               String?
  ocrStatus             String    @default("PENDING") // PENDING, REVIEWED, FLAGGED

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  document              Document  @relation(fields: [documentId], references: [id])

  @@index([organizationId])
  @@index([documentId])
  @@index([ocrStatus])
}

enum DocumentType {
  AADHAAR
  PAN
  PASSPORT
  VOTER_ID
  DRIVING_LICENSE
  DEGREE_CERTIFICATE
  TENTH_CERTIFICATE
  TWELFTH_CERTIFICATE
  POST_GRADUATION_CERTIFICATE
  EXPERIENCE_LETTER
  OFFER_LETTER_DOC
  JOINING_LETTER
  RELIEVING_LETTER
  BANK_STATEMENT
  CANCELLED_CHEQUE
  SALARY_SLIP_DOC
  PHOTO
  SIGNATURE
  RESIDENCE_PROOF
  PROFESSIONAL_CERTIFICATION
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  FLAGGED
  EXPIRED
  ISSUED
}

// =====================
// ATTENDANCE
// =====================

model AttendanceRecord {
  id              String           @id @default(uuid())
  employeeId      String
  date            DateTime         @db.Date
  checkIn         DateTime?
  checkOut        DateTime?
  totalHours      Decimal?         @db.Decimal(5, 2)
  status          AttendanceStatus @default(ABSENT)
  workMode        WorkMode
  source          AttendanceSource @default(MANUAL_APP)
  checkInLocation Json?
  checkOutLocation Json?
  ipAddress       String?
  deviceType      String?
  notes           String?
  activeMinutes      Int              @default(0)
  activityPulses     Int              @default(0)
  geofenceViolation  Boolean          @default(false)
  clockInCount       Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  breaks   Break[]
  regularization AttendanceRegularization?
  logs     AttendanceLog[]
  locationVisits   LocationVisit[]
  anomalies        AttendanceAnomaly[]
  overtimeRequests OvertimeRequest[]

  @@unique([employeeId, date])
  @@index([date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  HOLIDAY
  WEEKEND
  ON_LEAVE
  WORK_FROM_HOME
}

enum AttendanceSource {
  GEOFENCE_AUTO
  MANUAL_APP
  MANUAL_HR
  QR_CODE
  BIOMETRIC
}

model Break {
  id               String    @id @default(uuid())
  attendanceId     String
  startTime        DateTime
  endTime          DateTime?
  type             BreakType @default(LUNCH)
  durationMinutes  Int?

  attendance AttendanceRecord @relation(fields: [attendanceId], references: [id])
}

enum BreakType {
  LUNCH
  SHORT
  PRAYER
  CUSTOM
}

model AttendanceLog {
  id             String   @id @default(uuid())
  attendanceId   String
  action         String   // CLOCK_IN, CLOCK_OUT, RE_CLOCK_IN, BREAK_START, BREAK_END
  timestamp      DateTime @default(now())
  location       Json?    // { lat, lng, accuracy }
  notes          String?
  geofenceStatus String?  // INSIDE, OUTSIDE, NO_GEOFENCE
  distanceMeters Int?     // distance from office if geofence checked
  shiftName      String?
  ipAddress      String?

  attendance AttendanceRecord @relation(fields: [attendanceId], references: [id])

  @@index([attendanceId])
  @@index([attendanceId, timestamp])
}

model AttendanceRegularization {
  id           String   @id @default(uuid())
  attendanceId String   @unique
  employeeId   String
  reason       String
  requestedCheckIn  DateTime?
  requestedCheckOut DateTime?
  attachment   String?
  status       RegularizationStatus @default(PENDING)
  managerReviewedBy String?
  managerRemarks    String?
  managerReviewedAt DateTime?
  hrReviewedBy      String?
  hrRemarks         String?
  hrReviewedAt      DateTime?
  approvedBy   String?
  approverRemarks String?
  originalCheckIn   DateTime?
  originalCheckOut  DateTime?
  finalCheckIn      DateTime?
  finalCheckOut     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendance AttendanceRecord @relation(fields: [attendanceId], references: [id])
  employee   Employee         @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
}

enum RegularizationStatus {
  PENDING
  MANAGER_REVIEWED
  HR_REVIEWED
  APPROVED
  REJECTED
}

model AttendanceAnomaly {
  id             String            @id @default(uuid())
  attendanceId   String
  employeeId     String
  date           DateTime          @db.Date
  type           AnomalyType
  severity       AnomalySeverity   @default(MEDIUM)
  description    String
  metadata       Json?
  resolution     AnomalyResolution @default(PENDING)
  resolvedBy     String?
  resolvedAt     DateTime?
  resolverRemarks String?
  autoDetected   Boolean           @default(true)
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  attendance AttendanceRecord @relation(fields: [attendanceId], references: [id])
  employee   Employee         @relation(fields: [employeeId], references: [id])

  @@index([employeeId, date])
  @@index([organizationId, date])
  @@index([type])
  @@index([resolution])
}

enum AnomalyType {
  LATE_ARRIVAL
  EARLY_EXIT
  MISSING_PUNCH
  INSUFFICIENT_HOURS
  OUTSIDE_GEOFENCE
  DUPLICATE_PUNCH
  SUSPICIOUS_GAP
  LEAVE_OVERLAP
  HOLIDAY_ATTENDANCE
  LOCATION_MISMATCH
  UNAPPROVED_REMOTE
  POLICY_BREACH
  GPS_SPOOF
}

enum AnomalySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnomalyResolution {
  PENDING
  AUTO_RESOLVED
  MANAGER_APPROVED
  HR_APPROVED
  REJECTED
  DISMISSED
}

model GPSTrailPoint {
  id           String   @id @default(uuid())
  employeeId   String
  date         DateTime @db.Date
  lat          Decimal  @db.Decimal(10, 7)
  lng          Decimal  @db.Decimal(10, 7)
  accuracy     Decimal? @db.Decimal(6, 2)
  altitude     Decimal? @db.Decimal(8, 2)
  speed        Decimal? @db.Decimal(6, 2)
  heading      Decimal? @db.Decimal(5, 2)
  batteryLevel Int?
  timestamp    DateTime
  visitLabel   String?
  isVisitStop  Boolean  @default(false)
  stopDuration Int?

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, date])
}

model ProjectSiteCheckIn {
  id           String   @id @default(uuid())
  employeeId   String
  date         DateTime @db.Date
  siteName     String
  siteAddress  String?
  checkInPhoto String?
  checkInLat   Decimal? @db.Decimal(10, 7)
  checkInLng   Decimal? @db.Decimal(10, 7)
  notes        String?
  approvedBy   String?
  createdAt    DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, date])
}

model Geofence {
  id           String       @id @default(uuid())
  name         String
  type         GeofenceType @default(OFFICE)
  coordinates  Json
  radiusMeters Int?
  autoCheckIn  Boolean      @default(false)
  autoCheckOut Boolean      @default(false)
  strictMode   Boolean      @default(false)
  organizationId String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  officeLocation OfficeLocation?

  @@index([organizationId])
}

enum GeofenceType {
  OFFICE
  CLIENT_SITE
  RESTRICTED
}

// =====================
// LEAVE MANAGEMENT
// =====================

model LeaveType {
  id             String   @id @default(uuid())
  name           String
  code           String
  defaultBalance Decimal  @db.Decimal(5, 1)
  carryForward   Boolean  @default(false)
  maxCarryForward Decimal? @db.Decimal(5, 1)
  isPaid         Boolean  @default(true)
  minDays        Decimal  @default(0.5) @db.Decimal(3, 1)
  maxDays        Decimal? @db.Decimal(5, 1)
  noticeDays     Int      @default(0)
  gender         Gender?

  // Leave policy configuration
  applicableTo           String   @default("ALL")    // "ALL", "PROBATION", "CONFIRMED", "INTERN", "NOTICE_PERIOD", "ONBOARDING"
  applicableToRole       String?                      // null = all roles; "EMPLOYEE", "MANAGER", "HR", "ADMIN", "INTERN"
  applicableToEmployeeIds String?                     // JSON array of specific employee IDs — if set, overrides status/role filters
  maxPerMonth        Int?                         // Max leaves per month (null = unlimited)
  allowWeekendAdjacent Boolean @default(true)     // Can apply adjacent to weekends
  allowSameDay       Boolean  @default(false)     // Can apply on same day (e.g. sick leave)
  allowPastDates     Boolean  @default(false)     // Allow applying for past dates
  maxAdvanceDays     Int?                         // Max days ahead leave can be applied (null = unlimited)
  probationMonths    Int      @default(3)         // Probation duration in months
  requiresApproval   Boolean  @default(true)      // Needs manager/HR approval
  isActive           Boolean  @default(true)      // Soft toggle

  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]
  policyRules   LeavePolicyRule[]

  @@unique([code, organizationId])
  @@index([organizationId])
}

model LeaveBalance {
  id            String  @id @default(uuid())
  employeeId    String
  leaveTypeId   String
  year          Int
  allocated     Decimal @db.Decimal(5, 1)
  used          Decimal @default(0) @db.Decimal(5, 1)
  carriedForward Decimal @default(0) @db.Decimal(5, 1)
  pending       Decimal @default(0) @db.Decimal(5, 1)

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id            String             @id @default(uuid())
  employeeId    String
  leaveTypeId   String
  startDate     DateTime           @db.Date
  endDate       DateTime           @db.Date
  days          Decimal            @db.Decimal(4, 1)
  isHalfDay     Boolean            @default(false)
  halfDaySession String?
  reason        String
  status             LeaveRequestStatus @default(PENDING)
  approvedBy         String?
  approverRemarks    String?
  managerApprovedAt  DateTime?
  managerRemarks     String?
  attachmentUrl      String?
  // Leave-impact fields
  noticeHours        Int?               // hours between application and leave start
  backupEmployeeId   String?            // primary backup assignee
  handoverNotes      String?            // general handover notes
  acknowledgements   Json?              // { reviewedTasks, assignedHandover, acceptedVisibility }
  riskLevel          RiskLevel?         // cached from task audit
  riskScore          Int?               // cached from task audit
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  employee           Employee  @relation(fields: [employeeId], references: [id])
  leaveType          LeaveType @relation(fields: [leaveTypeId], references: [id])
  taskAudits         LeaveTaskAudit[]
  handovers          LeaveHandover[]
  approvalDecisions  LeaveApprovalDecision[]
  notificationLogs   LeaveNotificationLog[]

  @@index([employeeId, status])
  @@index([startDate, endDate])
  @@index([status])
}

enum LeaveRequestStatus {
  DRAFT
  PENDING
  MANAGER_APPROVED
  APPROVED
  APPROVED_WITH_CONDITION
  REJECTED
  CANCELLED
}

model Holiday {
  id              String   @id @default(uuid())
  name            String
  date            DateTime @db.Date
  type            String   @default("PUBLIC")  // PUBLIC, OPTIONAL, EVENT, CUSTOM
  isOptional      Boolean  @default(false)
  isHalfDay       Boolean  @default(false)
  halfDaySession  String?  // FIRST_HALF or SECOND_HALF (if isHalfDay)
  startTime       String?  // e.g. "09:30" for timed events
  endTime         String?  // e.g. "18:00"
  description     String?  // AI-generated or HR-written description
  color           String?  // Custom color hex for calendar display (e.g. #F97316 for events)
  notifyEmployees Boolean  @default(true)
  createdBy       String?  // userId who created it
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([date, organizationId])
  @@index([organizationId, date])
}

// Hybrid work schedule — defines which days are office vs WFH for hybrid employees
model HybridSchedule {
  id             String   @id @default(uuid())
  employeeId     String   @unique
  // Days 0=Sunday, 1=Monday, ..., 6=Saturday — store as JSON array of office days
  officeDays     Json     // e.g. [1, 2, 3] for Mon/Tue/Wed in office
  wfhDays        Json     // e.g. [4, 5] for Thu/Fri WFH
  effectiveFrom  DateTime @db.Date
  notes          String?
  setBy          String?  // userId of HR who set this
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([organizationId])
}

// =====================
// PAYROLL
// =====================

model SalaryComponentMaster {
  id               String   @id @default(uuid())
  name             String
  code             String   // e.g. BASIC, HRA, SHIFT_ALLOW
  type             ComponentType
  category         ComponentCategory @default(STANDARD)
  calculationRule  CalculationRule @default(FIXED)
  percentageOf     String?  // e.g. "BASIC" or "CTC" — which component or CTC to calculate % of
  defaultValue     Decimal? @db.Decimal(12, 2)
  defaultPercentage Decimal? @db.Decimal(5, 2)
  isTaxable        Boolean  @default(true)
  isStatutory      Boolean  @default(false)
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  description      String?
  organizationId   String
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@unique([code, organizationId])
  @@index([organizationId, type])
}

enum ComponentType {
  EARNING
  DEDUCTION
}

enum ComponentCategory {
  STANDARD     // Basic, HRA, DA etc.
  ALLOWANCE    // Shift, Night, City Compensatory
  BONUS        // Performance, Festival, Retention
  REIMBURSEMENT // Travel, Internet, Phone
  STATUTORY    // EPF, ESI, PT, TDS
  CUSTOM       // Any custom component
}

enum CalculationRule {
  FIXED          // Fixed amount
  PERCENTAGE_CTC // Percentage of CTC
  PERCENTAGE_BASIC // Percentage of Basic
  SLAB           // Slab-based (like PT)
  FORMULA        // Custom formula (future)
}

model SalaryTemplate {
  id               String             @id @default(uuid())
  name             String
  type             SalaryTemplateType
  description      String?
  ctc              Decimal            @db.Decimal(12, 2)
  basic            Decimal            @db.Decimal(12, 2)
  hra              Decimal            @db.Decimal(12, 2)
  da               Decimal?           @db.Decimal(12, 2)
  ta               Decimal?           @db.Decimal(12, 2)
  medicalAllowance Decimal?           @db.Decimal(12, 2)
  specialAllowance Decimal?           @db.Decimal(12, 2)
  lta              Decimal?           @db.Decimal(12, 2)
  performanceBonus Decimal?           @db.Decimal(12, 2)
  incomeTaxRegime  TaxRegime          @default(NEW_REGIME)
  components       Json?              // dynamic salary components (same shape as SalaryStructure)
  statutoryConfig  Json?              // statutory deduction overrides
  lockedFields     Json?              // string[] of fields HR cannot override when applying
  isDefault        Boolean            @default(false)
  isActive         Boolean            @default(true)
  organizationId   String
  createdBy        String
  updatedBy        String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  @@unique([name, organizationId])
  @@index([organizationId, type])
}

enum SalaryTemplateType {
  INTERN
  FULL_TIME
  CONTRACT
  CUSTOM
}

model SalaryStructure {
  id               String   @id @default(uuid())
  employeeId       String   @unique
  templateId       String?  // SalaryTemplate used (null = manual entry)
  templateName     String?  // snapshot of template name at time of application
  isCustom         Boolean  @default(false) // false = use component master defaults; true = custom per-employee components
  ctc              Decimal  @db.Decimal(12, 2)
  // Dynamic salary components stored as JSON array
  // Each: { name: string, type: "earning"|"deduction", value: number, isPercentage: boolean, percentage?: number }
  components       Json?
  // Configurable statutory deductions
  statutoryConfig  Json?
  // Legacy fixed columns (kept for backward compatibility with existing payroll records)
  basic            Decimal? @db.Decimal(12, 2)
  hra              Decimal? @db.Decimal(12, 2)
  da               Decimal? @db.Decimal(12, 2)
  ta               Decimal? @db.Decimal(12, 2)
  medicalAllowance Decimal? @db.Decimal(12, 2)
  specialAllowance Decimal? @db.Decimal(12, 2)
  lta              Decimal? @db.Decimal(12, 2)
  performanceBonus Decimal? @db.Decimal(12, 2)
  pfEmployee       Decimal? @db.Decimal(12, 2)
  pfEmployer       Decimal? @db.Decimal(12, 2)
  esiEmployee      Decimal? @db.Decimal(12, 2)
  esiEmployer      Decimal? @db.Decimal(12, 2)
  professionalTax  Decimal? @db.Decimal(12, 2)
  tds              Decimal? @db.Decimal(12, 2)
  incomeTaxRegime    TaxRegime @default(NEW_REGIME)
  enabledComponents  Json?
  lockedFields       Json?     // inherited from template — fields HR cannot edit
  effectiveFrom      DateTime
  version            Int       @default(1) // incremented on each revision
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model SalaryHistory {
  id               String          @id @default(uuid())
  employeeId       String
  changeType       SalaryChangeType
  ctc              Decimal         @db.Decimal(12, 2)
  components       Json?           // Snapshot of components at time of change
  // Legacy fixed columns
  basic            Decimal?        @db.Decimal(12, 2)
  hra              Decimal?        @db.Decimal(12, 2)
  da               Decimal?        @db.Decimal(12, 2)
  ta               Decimal?        @db.Decimal(12, 2)
  medicalAllowance Decimal?        @db.Decimal(12, 2)
  specialAllowance Decimal?        @db.Decimal(12, 2)
  lta              Decimal?        @db.Decimal(12, 2)
  templateId       String?         // template used at time of change
  templateName     String?         // snapshot — template may be renamed
  effectiveFrom    DateTime
  reason           String?
  changedBy        String          // userId
  changedByName    String?         // snapshot of user's display name
  previousCtc      Decimal?        @db.Decimal(12, 2) // previous CTC for quick diff
  organizationId   String
  createdAt        DateTime        @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
}

enum SalaryChangeType {
  INITIAL
  REVISION
  PROMOTION
  CORRECTION
  TEMPLATE_APPLIED
}

enum TaxRegime {
  OLD_REGIME
  NEW_REGIME
}

model PayrollRun {
  id          String          @id @default(uuid())
  month       Int
  year        Int
  status      PayrollRunStatus @default(DRAFT)
  processedBy String?
  processedAt DateTime?
  totalGross  Decimal?        @db.Decimal(14, 2)
  totalNet    Decimal?        @db.Decimal(14, 2)
  totalDeductions Decimal?    @db.Decimal(14, 2)
  approvedBy  String?
  approvedAt  DateTime?
  remarks     String?
  payDate     DateTime?       // scheduled pay date
  organizationId String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  records          PayrollRecord[]
  adjustments      PayrollAdjustment[]
  deletionRequests PayrollDeletionRequest[]

  @@unique([month, year, organizationId])
}

model PayrollDeletionRequest {
  id              String    @id @default(uuid())
  payrollRunId    String?                          // nullable after run is deleted
  organizationId  String
  requestedById   String                           // User.id of the HR who requested
  reason          String
  notes           String?
  status          String    @default("PENDING")    // PENDING | APPROVED | REJECTED
  rejectionReason String?
  reviewedById    String?                          // SuperAdmin User.id
  reviewedAt      DateTime?
  runMonth        Int                              // snapshot (kept after deletion)
  runYear         Int
  runLabel        String                           // e.g. "January 2025"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  payrollRun   PayrollRun?   @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  REVIEW
  APPROVED
  COMPLETED
  LOCKED
}

model PayrollRecord {
  id             String  @id @default(uuid())
  payrollRunId   String
  employeeId     String
  grossSalary    Decimal @db.Decimal(12, 2)
  netSalary      Decimal @db.Decimal(12, 2)
  basic          Decimal @db.Decimal(12, 2)
  hra            Decimal @db.Decimal(12, 2)
  otherEarnings  Json?
  epfEmployee    Decimal? @db.Decimal(12, 2)
  epfEmployer    Decimal? @db.Decimal(12, 2)
  esiEmployee    Decimal? @db.Decimal(12, 2)
  esiEmployer    Decimal? @db.Decimal(12, 2)
  professionalTax Decimal? @db.Decimal(12, 2)
  tds            Decimal? @db.Decimal(12, 2)
  otherDeductions Json?
  lopDays        Decimal  @default(0) @db.Decimal(6, 2) // stored as decimal to preserve half-day accuracy
  lopDeduction   Decimal? @db.Decimal(12, 2)
  workingDays    Int
  presentDays    Decimal  @default(0) @db.Decimal(6, 2) // stored as decimal (half-days = 0.5)
  amendedBy      String?
  amendedAt      DateTime?
  amendmentReason String?
  overtimeHours   Decimal?  @db.Decimal(6, 2)
  overtimeAmount  Decimal?  @db.Decimal(12, 2)
  adjustments     Json?     // snapshot of applied adjustments
  earningsBreakdown Json?   // detailed component-wise earnings
  deductionsBreakdown Json? // detailed component-wise deductions
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])
}

model PayrollAdjustment {
  id             String          @id @default(uuid())
  payrollRunId   String
  employeeId     String
  type           AdjustmentType
  componentName  String          // e.g. "Arrears - Basic", "Reimbursement", "Bonus"
  amount         Decimal         @db.Decimal(12, 2)
  isDeduction    Boolean         @default(false) // false = addition, true = deduction
  reason         String
  addedBy        String          // userId
  addedByName    String?
  approvedBy     String?         // userId
  approvalStatus AdjustmentApproval @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@index([payrollRunId, employeeId])
}

enum AdjustmentType {
  ARREARS
  REIMBURSEMENT
  BONUS
  INCENTIVE
  ADVANCE_DEDUCTION
  LOAN_RECOVERY
  OTHER
}

enum AdjustmentApproval {
  PENDING
  APPROVED
  REJECTED
}

