// =====================
// ONBOARDING DOCUMENT GATE
// =====================

model OnboardingDocumentGate {
  id                  String         @id @default(uuid())
  employeeId          String         @unique
  requiredDocs        DocumentType[]
  submittedDocs       DocumentType[] @default([])
  allSubmitted        Boolean        @default(false)
  offerLetterUnlocked Boolean        @default(false)
  unlockedAt          DateTime?
  unlockedBy          String?

  // KYC verification
  kycStatus           KycStatus      @default(PENDING)
  photoUrl            String?
  combinedPdfUploaded Boolean        @default(false)
  verifiedAt          DateTime?
  verifiedBy          String?
  rejectionReason     String?

  // Upload mode selection — set by employee at start of KYC
  uploadMode            String?      // COMBINED | SEPARATE
  fresherOrExperienced  String?      // FRESHER | EXPERIENCED
  highestQualification  String?      // TENTH | TWELFTH | GRADUATION | POST_GRADUATION | PHD

  // HR actions per-doc
  reuploadRequested     Boolean      @default(false)
  reuploadDocTypes      String[]     @default([])  // which doc types HR flagged for re-upload

  // Combined PDF intelligence results (from Python OCR classifier)
  combinedPdfAnalysis   Json?        // { detectedDocs: string[], missingDocs: string[], pageGroups: [...], suspicionScore: number, flags: [...] }

  // Per-document employee-visible reasons (HR sets these when rejecting individual docs)
  documentRejectReasons Json?        // { "PAN": "Blurred image", "AADHAAR": "Invalid format" }

  // HR review notes (internal only)
  hrReviewNotes         String?

  // Processing mode tracking
  processingMode        String?      // PYTHON_ADVANCED | NODE_FALLBACK | MANUAL_REVIEW_ONLY
  fallbackUsed          Boolean      @default(false)

  // Employee-visible simple status messages (set by system or HR)
  employeeVisibleReasons Json?       // string[] of plain-language reasons for employee

  // Missing / duplicate doc tracking
  missingDocuments      String[]     @default([])
  duplicateDocuments    String[]     @default([])

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

enum KycStatus {
  PENDING
  SUBMITTED
  PROCESSING
  PENDING_HR_REVIEW
  REUPLOAD_REQUIRED
  VERIFIED
  REJECTED
}

