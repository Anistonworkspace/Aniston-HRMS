<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production backend: HTTPS only, no cleartext permitted -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">hr.anistonav.com</domain>
    </domain-config>

    <!-- Capacitor WebView internal origin: HTTPS scheme -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
