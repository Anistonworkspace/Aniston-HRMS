<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location — precise + background required for Field GPS tracking -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service required for background GPS (Doze-exempt) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+: must declare foreground service type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Persistent "Field GPS Active" notification (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake lock — keeps CPU alive during offline GPS buffering -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Allow GpsRestartReceiver to restart the service after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Allow AlarmManager exact alarm (Android 12+) for service restart after task removal -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Android 13+ alternative exact-alarm permission (no user prompt needed unlike SCHEDULE_EXACT_ALARM) -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Battery optimization exemption — required to keep GPS service alive on Samsung/Xiaomi/Oppo/OnePlus -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!--
          Native GPS foreground service.
          android:stopWithTask="false"  — survives swipe-from-recents (only Force Stop kills it).
          android:foregroundServiceType="location" — required on Android 10+ for background GPS.
        -->
        <service
            android:name=".GpsTrackingService"
            android:exported="false"
            android:foregroundServiceType="location"
            android:stopWithTask="false" />

        <!--
          GpsRestartReceiver — handles:
            1. BOOT_COMPLETED / LOCKED_BOOT_COMPLETED  → restart service after device reboot
            2. Custom ACTION_RESTART_GPS               → restart service after task-removal AlarmManager fires
          android:exported="true" is required for BOOT_COMPLETED receivers (system sends the broadcast).
          android:directBootAware="true" lets it receive LOCKED_BOOT_COMPLETED before user unlocks.
        -->
        <receiver
            android:name=".GpsRestartReceiver"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="com.anistonav.hrms.RESTART_GPS" />
            </intent-filter>
        </receiver>

        <!-- ShiftReminderPlugin — receives AlarmManager alarm to fire shift-start notification -->
        <receiver
            android:name=".ShiftReminderPlugin$ShiftReminderReceiver"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

</manifest>
