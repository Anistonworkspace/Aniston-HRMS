{
  "name": "aniston-support",
  "version": "1.0.5",
  "description": "Aniston HRMS Desktop Support Agent",
  "main": "dist/main.js",
  "author": "Aniston Technologies LLP",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "dist": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --win --dir",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "active-win": "^8.1.0",
    "auto-launch": "^5.0.6",
    "electron-store": "^8.2.0",
    "form-data": "^4.0.0",
    "node-fetch": "^2.7.0",
    "screenshot-desktop": "^1.15.0",
    "sharp": "^0.33.2",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/auto-launch": "^5.0.5",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.9",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Anistonworkspace/Aniston-HRMS.git"
  },
  "build": {
    "appId": "com.aniston.support",
    "productName": "Aniston Support",
    "copyright": "Copyright © 2026 Aniston Technologies LLP",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "legalTrademarks": "Aniston Technologies LLP"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "aniston-support-setup.${ext}",
      "deleteAppDataOnUninstall": false
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/screenshot-desktop/**",
      "node_modules/sharp/**",
      "node_modules/active-win/**"
    ]
  }
}
