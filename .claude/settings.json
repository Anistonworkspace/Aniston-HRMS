{
  "project": {
    "name": "Aniston HRMS",
    "description": "Enterprise HRMS PWA with 3 attendance modes, AI recruitment, Indian payroll, glassmorphism UI",
    "type": "fullstack-web-app"
  },
  "context": {
    "primaryLanguage": "TypeScript",
    "frameworks": [
      "React 18",
      "Express.js 4",
      "Prisma ORM 5",
      "Vite 5",
      "FastAPI (Python)"
    ],
    "database": "PostgreSQL 16",
    "caching": "Redis 7",
    "styling": "Tailwind CSS v3 + shadcn/ui",
    "stateManagement": "Redux Toolkit + RTK Query",
    "animations": "Framer Motion",
    "taskQueue": "BullMQ",
    "realtime": "Socket.io",
    "ai": "Python FastAPI (pytesseract OCR, DeepSeek scoring)",
    "containerization": "Docker Compose",
    "testing": "Vitest + Playwright (planned)",
    "pwa": "Workbox service worker"
  },
  "conventions": {
    "codeStyle": "TypeScript strict, ESM modules",
    "apiPattern": "REST with { success, data, error, meta } envelope",
    "backendModulePattern": "controller/service/routes/validation per feature",
    "componentPattern": "Function components with hooks, co-located styles",
    "namingConvention": "camelCase for variables/functions, PascalCase for components/types",
    "idFormat": "UUID v4",
    "dateFormat": "ISO 8601",
    "currencyFormat": "INR with en-IN locale"
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git pull *)",
      "Bash(cd * && *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(echo *)",
      "Bash(chmod *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(rm *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(uvicorn *)",
      "Bash(docker *)",
      "Bash(docker compose *)",
      "Bash(docker-compose *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(pm2 *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(kill *)",
      "Bash(lsof *)",
      "Bash(ps *)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "MultiEdit(**)",
      "Glob(**)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_hover",
      "mcp__playwright__browser_select_option",
      "mcp__playwright__browser_navigate_back",
      "mcp__playwright__browser_tabs",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_network_requests",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_drag",
      "mcp__playwright__browser_handle_dialog",
      "mcp__playwright__browser_file_upload",
      "mcp__playwright__browser_install",
      "mcp__playwright__browser_run_code"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(git push *)",
      "Bash(git push origin *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Read(.env.production)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "autoMemoryEnabled": true,
  "includeGitInstructions": true,
  "respectGitignore": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-command.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/lint-on-save.sh"
          }
        ]
      }
    ]
  }
}